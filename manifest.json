{
  "manifest_version": 3,
  "name": "Block Poster",
  "description": "Turn images from any web page or screen capture into printable tiled poster PDFs.",
  "version": "0.1.0",
  "minimum_chrome_version": "116",
  "icons": {
    "16": "icons/icon-16.png",
    "32": "icons/icon-32.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },
  "permissions": [
    "activeTab",
    "clipboardRead",
    "contextMenus",
    "downloads",
    "scripting",
    "sidePanel",
    "storage"
  ],
  "host_permissions": ["https://blockposter.pro/*"],
  "optional_host_permissions": ["http://*/*", "https://*/*"],
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "action": {
    "default_title": "Open Block Poster",
    "default_icon": {
      "16": "icons/icon-16.png",
      "32": "icons/icon-32.png"
    }
  },
  "side_panel": {
    "default_path": "sidepanel.html"
  },
  "content_scripts": [
    {
      "matches": ["https://blockposter.pro/*"],
      "js": ["connect-bridge.js"],
      "run_at": "document_start"
    }
  ]
}
